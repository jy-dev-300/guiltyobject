# Required
CAFE24_CLIENT_ID=
CAFE24_CLIENT_SECRET=
CAFE24_MALL_ID=
CAFE24_SHOP_NO=1
CAFE24_PUBLIC_STORE_URL=

# Required for automatic refresh-token sourcing
CAFE24_REFRESH_TOKEN_SOURCE_URL=

# Optional
CAFE24_STORE_DOMAIN=
CAFE24_FRONT_API_KEY=
CAFE24_OAUTH_TOKEN_URL=
CAFE24_REFRESH_TOKEN_SOURCE_AUTH_HEADER=
CAFE24_ACCOUNT_URL=
CAFE24_LOGIN_URL=
CAFE24_CHECKOUT_URL=
FRAMER_HOME_URL=

# Optional fallback only: use when you are not sourcing the refresh token from a URI.
CAFE24_REFRESH_TOKEN=

# Optional fallback only: companion expiry for the env refresh token above.
CAFE24_REFRESH_TOKEN_EXPIRES_AT=

# Optional fallback only: static bearer token if refresh-token flow is unavailable.
CAFE24_ACCESS_TOKEN=

# Optional fallback only: direct web-component token if backend token minting is unavailable.
CAFE24_WEB_COMPONENT_ACCESS_TOKEN=
